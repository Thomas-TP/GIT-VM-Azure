{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "git-vm-portal-azure",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "observability": { "enabled": true },

  "assets": {
    "directory": "./web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    // Les routes de redirection OIDC (navigations navigateur) doivent atteindre le
    // Worker AVANT le fallback SPA des assets. Sinon /auth/login et /auth/callback
    // renvoient index.html → boucle de login infinie. /api/* et /healthz inclus par sûreté.
    "run_worker_first": ["/auth/*", "/api/*", "/healthz"]
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "git_vm_portal_azure",
      "database_id": "8b53a9b3-4bb1-492a-b9c9-10d8e7769987"
    }
  ],

  // Non-secret config. Secrets (Azure SP secret, Entra client secret, session
  // secret, EmailJS private key) are set with `wrangler secret put` — never here.
  "vars": {
    "ALLOWED_EMAIL_DOMAINS": "satom.ch,git.swiss",
    "ADMIN_EMAILS": "thomas.prudhomme@satom.ch,thomas.prudhomme@git.swiss",

    // Login SSO (app Entra « GIT-VM-Azure »)
    "ENTRA_TENANT_ID": "33a7a298-4cf4-4f62-914a-d32bba54de5a",
    "ENTRA_CLIENT_ID": "09d86c63-25eb-4b64-90f1-9d1327e314a4",

    // Compute Azure (service principal « Claude », Owner sur l'abonnement)
    "AZURE_TENANT_ID": "33a7a298-4cf4-4f62-914a-d32bba54de5a",
    "AZURE_CLIENT_ID": "50f50b56-3510-467a-8e05-61081972daf6",
    "AZURE_SUBSCRIPTION_ID": "2ffd87ba-1361-4458-9e40-6a71af0615d7",
    "AZURE_LOCATION": "switzerlandnorth",
    "AZURE_RESOURCE_GROUP": "git-vm-portal",
    // Resource ids complets — remplis par scripts/azure-setup.mjs (voir docs/DEPLOYMENT.md).
    "AZURE_SUBNET_ID": "/subscriptions/2ffd87ba-1361-4458-9e40-6a71af0615d7/resourceGroups/git-vm-portal/providers/Microsoft.Network/virtualNetworks/git-vm-portal-vnet/subnets/default",
    "AZURE_NSG_ID": "/subscriptions/2ffd87ba-1361-4458-9e40-6a71af0615d7/resourceGroups/git-vm-portal/providers/Microsoft.Network/networkSecurityGroups/git-vm-portal-nsg",

    "APP_URL": "https://git-vm-portal-azure.satom-openstack.workers.dev",
    "GRAFANA_URL": "",
    "MAIL_ENABLED": "true",
    "SCHEDULED_STOP": "true",
    "IDLE_STOP": "true",
    "IDLE_STOP_HOURS": "3",
    "HARDENING": "true",
    "SENTRY_DSN": "",
    "EMAILJS_PUBLIC_KEY": "KIKcUV9eCQouP22hT",
    "EMAILJS_SERVICE_ID": "service_aeuc86a",
    "EMAILJS_TEMPLATE_ID": "template_za3761l"
  },

  "triggers": {
    // toutes les 2 min : réconciliation Azure↔DB (provisioning→active, drift, plannings,
    // retries, échéances, idle-stop, snapshots). 19:00 UTC : extinction nocturne.
    "crons": ["*/2 * * * *", "0 19 * * *"]
  }
}
